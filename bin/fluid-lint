#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',      // standalone: own vendor/
    __DIR__ . '/../../../autoload.php',        // regular composer installation in vendor/
    __DIR__ . '/../../../vendor/autoload.php', // path-repository inside packages/
];

$autoloadFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        $autoloadFound = true;
        break;
    }
}

if (!$autoloadFound) {
    fwrite(STDERR, 'Autoloader not found. Run: composer install' . PHP_EOL);
    exit(1);
}

use OliverThiele\FluidLinter\Config\LintConfig;
use OliverThiele\FluidLinter\Linter;
use OliverThiele\FluidLinter\Reporter\ConsoleReporter;
use OliverThiele\FluidLinter\Reporter\GithubActionsReporter;
use OliverThiele\FluidLinter\Reporter\JsonReporter;
use OliverThiele\FluidLinter\Result\FixStatus;
use OliverThiele\FluidLinter\Rule\CdataSectionRule;
use OliverThiele\FluidLinter\Rule\DebugViewHelperRule;
use OliverThiele\FluidLinter\Rule\DeprecatedViewHelperRule;
use OliverThiele\FluidLinter\Rule\FixableFileRuleInterface;
use OliverThiele\FluidLinter\Rule\FluidFileExtensionRule;
use OliverThiele\FluidLinter\Rule\HtmlNamespaceAttributeRule;
use OliverThiele\FluidLinter\Rule\HttpsNamespaceRule;
use OliverThiele\FluidLinter\Rule\ParseFuncTSPathRule;
use OliverThiele\FluidLinter\Rule\TypographicQuotesRule;
use OliverThiele\FluidLinter\Rule\UnderscoreVariableRule;
use OliverThiele\FluidLinter\Rule\XmlDeclarationRule;

$arguments = array_slice($argv, 1);
$format = 'console';
$configFile = null;
$typo3VersionOverride = null;
$fix = false;
$allowRisky = false;
$paths = [];

foreach ($arguments as $argument) {
    if ($argument === '--format=github') { $format = 'github'; continue; }
    if ($argument === '--format=json')   { $format = 'json';   continue; }
    if ($argument === '--fix')           { $fix = true;        continue; }
    if ($argument === '--allow-risky')   { $allowRisky = true; continue; }
    if (str_starts_with($argument, '--config=')) {
        $configFile = substr($argument, strlen('--config='));
        continue;
    }
    if (str_starts_with($argument, '--typo3-version=')) {
        $typo3VersionOverride = (int)substr($argument, strlen('--typo3-version='));
        continue;
    }
    if (!str_starts_with($argument, '--')) {
        $paths[] = $argument;
    }
}

if ($paths === []) {
    fwrite(STDERR, 'Usage: fluid-lint [--format=github|json] [--fix [--allow-risky]] [--config=<file>] [--typo3-version=<major>] <path> [<path>...]' . PHP_EOL);
    fwrite(STDERR, 'Example: fluid-lint --config=.fluid-lint.live.php packages/' . PHP_EOL);
    exit(1);
}

// Load config: explicit --config flag, then auto-detect .fluid-lint.php in CWD
if ($configFile !== null) {
    if (!file_exists($configFile)) {
        fwrite(STDERR, sprintf('Config file not found: %s' . PHP_EOL, $configFile));
        exit(1);
    }
    $config = require $configFile;
} elseif (file_exists(getcwd() . '/.fluid-lint.php')) {
    $config = require getcwd() . '/.fluid-lint.php';
} else {
    $config = new LintConfig();
}

if (!$config instanceof LintConfig) {
    fwrite(STDERR, 'Config file must return an instance of LintConfig.' . PHP_EOL);
    exit(1);
}

if ($typo3VersionOverride !== null) {
    $config->setTypo3Version($typo3VersionOverride);
}

$linter = new Linter(config: $config);
$linter->addRule(new TypographicQuotesRule());
$linter->addRule(new HtmlNamespaceAttributeRule());
$linter->addRule(new HttpsNamespaceRule());
$linter->addRule(new UnderscoreVariableRule());
$linter->addRule(new ParseFuncTSPathRule());
$linter->addRule(new XmlDeclarationRule());
$linter->addRule(new CdataSectionRule());
$linter->addRule(new DebugViewHelperRule());
$linter->addRule(new FluidFileExtensionRule());
$linter->addRule(new DeprecatedViewHelperRule($config->getTypo3Version() ?? 0));

$reporter = match ($format) {
    'github' => new GithubActionsReporter(),
    'json'   => new JsonReporter(),
    default  => new ConsoleReporter(),
};

$results = [];
foreach ($paths as $path) {
    if (is_dir($path)) {
        $results = array_merge($results, $linter->lintDirectory($path));
    } elseif (is_file($path)) {
        $results[$path] = $linter->lintFile($path);
    } else {
        fwrite(STDERR, sprintf('Path not found: %s' . PHP_EOL, $path));
        exit(1);
    }
}

$reporter->report($results);

// Apply automatic fixes when --fix is given.
// Fix messages always go to STDERR so they don't pollute --format=json or --format=github stdout.
// At most one fix is applied per file per run: after a successful fix the file content on disk
// has changed, so subsequent rules must not operate on stale violation data. Re-run fluid-lint
// to apply further fixes.
//
// $fixedRules tracks which (file, rule) pairs were successfully fixed, so the exit-code check
// below only ignores those specific violations — unfixable violations in the same file still
// contribute to the exit code.
/** @var array<string, array<string, true>> $fixedRules  keyed by filePath → ruleName */
$fixedRules = [];

if ($fix) {
    $ruleMap = [];
    foreach ($linter->getRules() as $rule) {
        $ruleMap[$rule->getName()] = $rule;
    }

    $appliedCount = 0;
    $skippedCount = 0;

    foreach ($results as $filePath => $result) {
        if (!$result->hasViolations()) {
            continue;
        }

        $processedRules = [];
        foreach ($result->getViolations() as $violation) {
            if (isset($processedRules[$violation->rule])) {
                continue;
            }
            $processedRules[$violation->rule] = true;

            $rule = $ruleMap[$violation->rule] ?? null;
            if (!$rule instanceof FixableFileRuleInterface) {
                continue;
            }

            $fixResult = $rule->fix($filePath, $allowRisky);

            if ($fixResult->status === FixStatus::Applied) {
                $appliedCount++;
                $fixedRules[$filePath][$violation->rule] = true;
                fwrite(STDERR, sprintf('  FIXED  %s: %s' . PHP_EOL, $filePath, $fixResult->description));
                // Stop after the first successful fix for this file: the file on disk has changed
                // and subsequent rules would operate on stale violation data.
                break;
            } elseif ($fixResult->status === FixStatus::Skipped) {
                $skippedCount++;
                fwrite(STDERR, sprintf('  SKIP   %s: %s' . PHP_EOL, $filePath, $fixResult->description));
            }
        }
    }

    if ($appliedCount > 0 || $skippedCount > 0) {
        fwrite(STDERR, PHP_EOL);
        if ($appliedCount > 0) {
            fwrite(STDERR, sprintf('Applied %d fix(es).' . PHP_EOL, $appliedCount));
        }
        if ($skippedCount > 0) {
            fwrite(STDERR, sprintf('%d fix(es) skipped — add --allow-risky to apply destructive operations.' . PHP_EOL, $skippedCount));
        }
    }
}

// Exit code: only skip violations that were actually fixed (rule-level granularity).
// A file with one fixed and one unfixed error still exits with code 1.
foreach ($results as $filePath => $result) {
    foreach ($result->getViolations() as $violation) {
        if ($violation->severity !== 'error') {
            continue;
        }
        if (isset($fixedRules[$filePath][$violation->rule])) {
            continue;
        }
        exit(1);
    }
}

exit(0);