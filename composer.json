{
    "name": "oliverthiele/typo3-fluid-linter",
    "description": "A linter for TYPO3 Fluid templates — catches typographic quotes, deprecated syntax, and Fluid 5 breaking changes",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Oliver Thiele",
            "email": "mail@oliver-thiele.de",
            "homepage": "https://www.oliver-thiele.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OliverThiele\\FluidLinter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OliverThiele\\FluidLinter\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fluid-lint"
    ],
    "scripts": {
        "phpstan": "phpstan analyse",
        "php-cs-fixer": "vendor/bin/php-cs-fixer fix",
        "phpunit": "vendor/bin/phpunit",
        "code-quality": [
            "@phpstan",
            "@php-cs-fixer",
            "@phpunit"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
